RUNCOMFY_API_KEY=1dc4a607-39c3-4382-b796-ec8cda38d84c
RUNCOMFY_BASE_URL=https://api.runcomfy.net/prod/v1
RUNCOMFY_WORKFLOW_CONFIG=./config/workflows.local.json

# Transcription provider: `faster-whisper` or `openai`.
TRANSCRIBE_PROVIDER=faster-whisper
FASTER_WHISPER_PYTHON=.\.venv-faster-whisper\Scripts\python.exe
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5

# Optional: upload local image/video files to a public S3-compatible bucket first.
# Set ASSET_S3_PUBLIC_BASE_URL for public buckets, or ASSET_S3_SIGNED_URL_EXPIRES_SEC for signed URLs.
ASSET_S3_ENDPOINT=
ASSET_S3_REGION=auto
ASSET_S3_BUCKET=
ASSET_S3_ACCESS_KEY_ID=
ASSET_S3_SECRET_ACCESS_KEY=
ASSET_S3_PUBLIC_BASE_URL=
ASSET_S3_SIGNED_URL_EXPIRES_SEC=0
ASSET_S3_FORCE_PATH_STYLE=false
ASSET_S3_PREFIX=runcomfy-inputs

# OpenAI-compatible endpoint for transcription and script rewriting.
# Leave empty if you want to use the fallback local planner only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_REWRITE_MODEL=gpt-4.1-mini

# Optional default style hint for rewritten scripts.
REWRITE_STYLE=中文短视频口播，逻辑更紧，避免原句复刻，保留光伏行业信息密度
